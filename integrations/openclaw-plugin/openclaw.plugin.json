{
  "id": "flockmem-memory",
  "name": "FlockMem Memory Bridge",
  "version": "0.1.4",
  "description": "Lightweight OpenClaw plugin for FlockMem memory write/retrieve and cross-session context recall.",
  "author": "FlockMem",
  "kind": "memory",
  "entry": "./index.ts",
  "permissions": {
    "network": true,
    "fileSystem": false,
    "hooks": ["before_agent_start", "agent_end"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:20195",
        "description": "FlockMem API base URL"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 120000,
        "default": 25000
      },
      "bearerToken": {
        "type": "string",
        "description": "Optional FlockMem bearer token"
      },
      "basicUser": {
        "type": "string",
        "description": "Optional FlockMem basic auth username"
      },
      "basicPassword": {
        "type": "string",
        "description": "Optional FlockMem basic auth password"
      },
      "defaultUserId": {
        "type": "string",
        "description": "Default retrieval user scope"
      },
      "defaultGroupId": {
        "type": "string",
        "description": "Default retrieval group scope"
      },
      "defaultSender": {
        "type": "string",
        "default": "openclaw-bot",
        "description": "Default sender used when writing memory"
      },
      "defaultAgentId": {
        "type": "string",
        "default": "main",
        "description": "Fallback agent id when hook event omits agent/session identity"
      },
      "defaultTopK": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 8
      },
      "defaultRetrieveMethod": {
        "type": "string",
        "enum": ["keyword", "vector", "hybrid", "rrf", "agentic"],
        "default": "agentic"
      },
      "defaultDecisionMode": {
        "type": "string",
        "enum": ["static", "rule", "agent"],
        "default": "rule"
      },
      "groupStrategy": {
        "type": "string",
        "enum": ["shared", "per_role", "per_user"],
        "default": "per_role",
        "description": "How to assign group_id when request doesn't provide one"
      },
      "sharedGroupId": {
        "type": "string",
        "default": "shared:openclaw",
        "description": "Shared group id used when groupStrategy=shared"
      },
      "autoSenderFromAgent": {
        "type": "boolean",
        "default": true,
        "description": "Infer sender/user from agent id and session key when possible"
      },
      "autoInjectOnStart": {
        "type": "boolean",
        "default": true,
        "description": "Automatically prepend recalled memory context before agent start"
      },
      "bootstrapQuery": {
        "type": "string",
        "description": "Optional fixed query used for startup recall"
      },
      "bootstrapTopK": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 6
      },
      "autoCaptureOnEnd": {
        "type": "boolean",
        "default": true,
        "description": "Persist latest dialogue turn at agent end"
      },
      "autoCaptureCompression": {
        "type": "boolean",
        "default": true,
        "description": "Persist compact context summary at agent end"
      },
      "inheritPrimaryModel": {
        "type": "boolean",
        "default": true,
        "description": "Whether OpenClaw primary model should be synced into FlockMem config.json"
      },
      "primaryModelSnapshot": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provider": {
            "type": "string",
            "default": ""
          },
          "baseUrl": {
            "type": "string",
            "default": ""
          },
          "model": {
            "type": "string",
            "default": ""
          }
        },
        "default": {
          "provider": "",
          "baseUrl": "",
          "model": ""
        },
        "description": "Last OpenClaw primary model snapshot collected during install/sync"
      },
      "primaryModelSyncStatus": {
        "type": "string",
        "default": "not_synced",
        "description": "Latest install-time primary-model sync status"
      },
      "senderMap": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "default": {},
        "description": "Map OpenClaw agent_id -> FlockMem sender"
      },
      "channelGroupMap": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "default": {},
        "description": "Map OpenClaw channel -> FlockMem group_id"
      },
      "sharePolicy": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "readableAgents": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "writableAgents": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          }
        },
        "default": {},
        "description": "Optional ACL for each group_id. Empty list means unrestricted."
      },
      "compressionMaxChars": {
        "type": "integer",
        "minimum": 200,
        "maximum": 12000,
        "default": 2500
      },
      "compressionMode": {
        "type": "string",
        "enum": ["truncate", "llm_summary", "hybrid"],
        "default": "truncate",
        "description": "Compression strategy for agent_end context capture"
      },
      "compressionTimeoutMs": {
        "type": "integer",
        "minimum": 120,
        "maximum": 5000,
        "default": 280,
        "description": "Timeout budget for llm_summary/hybrid compression path"
      },
      "compressionMinTurns": {
        "type": "integer",
        "minimum": 1,
        "maximum": 24,
        "default": 2,
        "description": "Skip compression capture when available user/assistant turns are below this value"
      },
      "compressionLlmBaseUrl": {
        "type": "string",
        "description": "Optional OpenAI-compatible chat completion base URL for compression model"
      },
      "compressionLlmApiKey": {
        "type": "string",
        "description": "Optional API key for compression LLM"
      },
      "compressionLlmModel": {
        "type": "string",
        "description": "Optional model id for compression LLM"
      },
      "debug": {
        "type": "boolean",
        "default": false
      }
    }
  },
  "uiHints": {
    "category": "memory",
    "icon": "database"
  }
}

